# ============================================================================
# NOC Toolkit - Centralized Environment Configuration
# ============================================================================
# This file contains all environment variables for all tools in the toolkit.
# Copy this file to .env and fill in your actual values.
#
# IMPORTANT: Never commit the .env file with real credentials!
# ============================================================================

# ============================================================================
# PagerDuty API Configuration
# ============================================================================
# Used by: pd-jira-tool, pagerduty-job-extractor
# Get your API token from: https://your-domain.pagerduty.com/api_keys
PAGERDUTY_API_TOKEN=your_pagerduty_api_token_here

# ============================================================================
# Jira Configuration
# ============================================================================
# Used by: pd-jira-tool
# REQUIRED: Your Jira server URL
JIRA_SERVER_URL=https://jira.yourcompany.com

# ----------------------------------------------------------------------------
# Option 1: Jira Server/Data Center Authentication (RECOMMENDED for on-premise)
# ----------------------------------------------------------------------------
# Use Personal Access Token for Jira Server or Data Center instances
# Generate token at: https://jira.yourcompany.com/secure/ViewProfile.jspa?selectedTab=com.atlassian.pats.pats-plugin:jira-user-personal-access-tokens
JIRA_PERSONAL_ACCESS_TOKEN=your_personal_access_token_here

# ----------------------------------------------------------------------------
# Option 2: Jira Cloud Authentication
# ----------------------------------------------------------------------------
# Use email + API token for Jira Cloud (*.atlassian.net)
# Generate token at: https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_EMAIL=your-email@example.com
# JIRA_API_TOKEN=your_jira_api_token_here

# ============================================================================
# Tool-Specific Configuration
# ============================================================================

# PagerDuty-Jira Tool Settings
# ----------------------------------------------------------------------------
# Snooze duration in hours (default: 6.0)
# SNOOZE_DURATION_HOURS=6.0

# ============================================================================
# PagerDuty Monitor Configuration
# ============================================================================
# Used by: pd-monitor
# Automatically refreshes incident acknowledgments to prevent auto-resolve

# Acknowledge threshold in hours before expiry (default: 4.0)
# PagerDuty auto-resolves after 6 hours, so 4.0 gives 2-hour safety buffer
# MONITOR_ACKNOWLEDGE_THRESHOLD_HOURS=4.0

# Comment pattern to detect (case-insensitive, default: "working on it")
# Used to determine refresh strategy
# MONITOR_COMMENT_PATTERN=working on it

# Hours to consider incident as "new" (default: 1.0)
# New incidents get "working on it" comment added automatically
# MONITOR_NEW_INCIDENT_THRESHOLD_HOURS=1.0

# Maximum auto-refreshes before requiring manual update (default: 3)
# Prevents infinite refresh loops
# MONITOR_MAX_AUTO_REFRESHES=3

# Path to state file for tracking refresh counts (default: ~/.pd-monitor-state.json)
# MONITOR_STATE_FILE=~/.pd-monitor-state.json

# Enable dry-run mode by default (default: false)
# MONITOR_DRY_RUN=false

# Enable verbose output by default (default: false)
# MONITOR_VERBOSE=false

# ============================================================================
# General Toolkit Settings (Optional)
# ============================================================================
# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO

# Output directory for exports and reports
# OUTPUT_DIR=./output

# Timezone for date/time operations
# TIMEZONE=UTC

# ============================================================================
# Notes:
# ----------------------------------------------------------------------------
# - For Jira Server/Data Center: Only JIRA_PERSONAL_ACCESS_TOKEN is needed
# - For Jira Cloud: Both JIRA_EMAIL and JIRA_API_TOKEN are needed
# - Uncomment the authentication method you need (comment out the other)
# - All tools will automatically load variables from this file
# ============================================================================
