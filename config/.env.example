# NOC Toolkit - Environment Variables Example
# =============================================
# Copy this file to .env and fill in your actual values
# Never commit the .env file with real credentials!

# PagerDuty Configuration
# -----------------------
# Get your API token from: https://your-domain.pagerduty.com/api_keys
PAGERDUTY_API_TOKEN=your_pagerduty_api_token_here

# Jira Configuration
# ------------------
# Get your API token from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_EMAIL=your_email@example.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_BASE_URL=https://your-domain.atlassian.net

# Tool-Specific Settings
# ----------------------
# Add any additional tool-specific environment variables below

# Example: Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO

# Example: Output directory for exports
# OUTPUT_DIR=./output
